# Copy to .env and fill in real values. .env is git-ignored.

# --- LLM (Claude via Microsoft Foundry / Azure AI Foundry) ---
ANTHROPIC_FOUNDRY_API_KEY=your-foundry-api-key
# Full endpoint base URL (Azure AI Foundry portal → resource → Overview / Endpoints):
ANTHROPIC_FOUNDRY_BASE_URL=https://<resource>.services.ai.azure.com/anthropic/
# ...or set the bare resource name instead of base_url (SDK expands it to the URL above):
# ANTHROPIC_FOUNDRY_RESOURCE=<resource>
# On Foundry, LLM_MODEL is the DEPLOYMENT name (not the public Anthropic model id).
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=16000
# Adaptive thinking (Claude 4.6+ deployments; beta on Foundry). Set false if unsupported.
LLM_THINKING=true

# --- Service ---
APP_NAME=implementation-service
LOG_LEVEL=INFO

# --- Database (PostgreSQL) — used later for workflow state ---
# DATABASE_URL=postgresql://user:password@localhost:5432/implementation

# --- Workspace ---
WORKSPACE_DIR=app/workspace

# --- exec-sandbox MCP server ---
# Set true to connect the MCPExecutor when the app starts (needs the exec-sandbox running).
SANDBOX_ENABLED=false
SANDBOX_MCP_URL=http://localhost:8080/mcp
SANDBOX_MCP_TRANSPORT=streamable_http
