# Copy to .env and fill in real values. .env is git-ignored.

# --- LLM (Claude via Microsoft Foundry / Azure AI Foundry) ---
ANTHROPIC_FOUNDRY_API_KEY=your-foundry-api-key
# Full endpoint base URL (Azure AI Foundry portal → resource → Overview / Endpoints):
ANTHROPIC_FOUNDRY_BASE_URL=https://<resource>.services.ai.azure.com/anthropic/
# ...or set the bare resource name instead of base_url (SDK expands it to the URL above):
# ANTHROPIC_FOUNDRY_RESOURCE=<resource>
# On Foundry, LLM_MODEL is the DEPLOYMENT name (not the public Anthropic model id).
LLM_MODEL=claude-sonnet-4-6
# A work item is one whole module (several files per reply), so raise the output budget.
LLM_MAX_TOKENS=32000
# Per-request wall-clock budget (seconds) for a single LLM call.
LLM_TIMEOUT_SECONDS=600
# Adaptive thinking (Claude 4.6+ deployments; beta on Foundry). Set false if unsupported.
LLM_THINKING=true

# --- Service ---
APP_NAME=implementation-service
LOG_LEVEL=INFO

# --- GitHub publish (demo publish flow) ---
# PAT used to create the repo + push. The project is published AS this token's owner, so you can
# publish under an account the local `gh` CLI is NOT logged into. Needs the `repo` scope.
GITHUB_PAT=your-github-pat
# Optional: the account/org that should own the repo. Leave blank to use the token's own account.
GITHUB_OWNER=

# --- Database (PostgreSQL) — used later for workflow state ---
# DATABASE_URL=postgresql://user:password@localhost:5432/implementation

# --- Workspace ---
WORKSPACE_DIR=app/workspace

# --- exec-sandbox MCP server ---
# Set true to connect the MCPExecutor when the app starts (needs the exec-sandbox running).
SANDBOX_ENABLED=false
SANDBOX_MCP_URL=http://localhost:8080/mcp
SANDBOX_MCP_TRANSPORT=streamable_http

# --- Code Review (clones the generated PUBLIC repo into an ephemeral sandbox) ---
# The review agent clones repo_url, runs ruff/eslint (+ sonar-scanner) inside a throwaway
# container, tears it down, and writes a Markdown report to REPORTS_DIR. No code is executed and
# no repo token is needed (public repos). Build the sandbox image first:
#   docker build -t sdlc-review-sandbox:latest tools/review-sandbox   (from repo root)
REVIEW_SANDBOX_IMAGE=sdlc-review-sandbox:latest
REVIEW_SANDBOX_TIMEOUT=900
REPORTS_DIR=reports
# Git working model: all phases work on this branch; merged -> main only after Security passes.
WORKING_BRANCH=dev

# --- SonarQube static analysis (integrations/sonarqube.py) ---
# 1. Start the server:   docker compose up -d      (see this service's docker-compose.yml)
# 2. Open http://localhost:9000  (login admin/admin, change password)
# 3. Create a project with key = SONARQUBE_PROJECT_KEY below (Projects -> Create -> Manually)
# 4. My Account -> Security -> Generate a token; paste it into SONARQUBE_TOKEN
# 5. Set SONARQUBE_ENABLED=true
#
# TWO URLs for the SAME server (different network vantage points):
#   * SONARQUBE_SCANNER_URL — used by sonar-scanner INSIDE the sandbox container (upload).
#                             Use host.docker.internal so the container reaches the host.
#   * SONARQUBE_URL         — used by the agent ON THE HOST to read issues back. Use localhost.
# Left disabled, the review runs on ruff/eslint + the LLM alone (no Sonar issues).
SONARQUBE_ENABLED=false
SONARQUBE_URL=http://localhost:9000
SONARQUBE_SCANNER_URL=http://host.docker.internal:9000
SONARQUBE_TOKEN=your-sonar-token-here
SONARQUBE_PROJECT_KEY=sdlc-implementation
SONARQUBE_TIMEOUT=30

# Password for the DEDICATED SonarQube Postgres in docker-compose.yml (compose-only; the app
# never reads this). Keep it in sync between the sonarqube and sonar-db services.
SONAR_DB_PASSWORD=sonar
